local function makeSlider(yPos, labelText, iconText, minV, maxV, onChange)
	local row = Instance.new("Frame", content)
	row.Size                   = UDim2.new(1, -24, 0, 44)
	row.Position               = UDim2.new(0, 12, 0, yPos)
	row.BackgroundTransparency = 1
	row.ZIndex                 = 2

