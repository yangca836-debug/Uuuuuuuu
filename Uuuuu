local function makeToggleBtn(parent, yPos, labelOn, labelOff, initVal, onChange)
	local btn = Instance.new("TextButton", parent)
	btn.Size = UDim2.new(1,-24,0,22)
	btn.Position = UDim2.new(0,12,0,yPos)
	btn.BorderSizePixel = 0
	btn.TextSize = 8
	btn.Font = Enum.Font.GothamBold
	btn.ZIndex = 3
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,5)
	local st = Instance.new("UIStroke", btn)
	st.Color = Color3.fromRGB(180,180,180)
	st.Thickness = 1
	st.Transparency = 0.3

	local val = initVal
	local function refresh()
		if val then
			btn.Text = labelOn
			btn.BackgroundColor3 = Color3.fromRGB(55,55,60)
			btn.TextColor3 = Color3.fromRGB(220,220,220)
		else
			btn.Text = labelOff
			btn.BackgroundColor3 = Color3.fromRGB(25,25,28)
			btn.TextColor3 = Color3.fromRGB(140,140,140)
		end
	end
	refresh()
	btn.MouseButton1Click:Connect(function()
		val = not val
		onChange(val)
		refresh()
	end)
	return btn
end

