local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

-- ==================== CONFIG ====================
local CIRCLE_RADIUS = 150
local MAX_DISTANCE = 500
local AUTO_FIRE = true
local FIRE_RATE = 0.1
local TOOL_NAME = "Gun"
-- ================================================

-- ==================== GUI ====================
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AimbotGui"
ScreenGui.ResetOnSpawn = false
ScreenGui.IgnoreGuiInset = true
ScreenGui.Parent = PlayerGui

local Circle = Instance.new("Frame")
Circle.Size = UDim2.new(0, CIRCLE_RADIUS * 2, 0, CIRCLE_RADIUS * 2)
Circle.Position = UDim2.new(0.5, -CIRCLE_RADIUS, 0.5, -CIRCLE_RADIUS)
Circle.BackgroundTransparency = 1
Circle.BorderSizePixel = 0
Circle.Active = true
Circle.Parent = ScreenGui

Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

local UIStroke = Instance.new("UIStroke")
UIStroke.Color = Color3.fromRGB(255, 50, 50)
UIStroke.Thickness = 2
UIStroke.Parent = Circle

local CenterDot = Instance.new("Frame")
CenterDot.Size = UDim2.new(0, 6, 0, 6)
CenterDot.Position = UDim2.new(0.5, -3, 0.5, -3)
CenterDot.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
CenterDot.BorderSizePixel = 0
CenterDot.Parent = ScreenGui
Instance.new("UICorner", CenterDot).CornerRadius = UDim.new(1, 0)

-- ==================== FUNCTIONS ====================

local function getHeadPosition(character)
	local head = character:FindFirstChild("Head")
	if head then return head.Position end
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if hrp then return hrp.Position end
	return nil
end

local function worldToScreen(pos)
	local screenPos, onScreen = Camera:WorldToScreenPoint(pos)
	return Vector2.new(screenPos.X, screenPos.Y), onScreen
end

local function hasLineOfSight(targetCharacter)
	local myChar = LocalPlayer.Character
	local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return false end

	local targetHead = targetCharacter:FindFirstChild("Head")
	if not targetHead then return false end

	local origin = myHRP.Position + Vector3.new(0, 1.5, 0)
	local target = targetHead.Position

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {myChar, targetCharacter}

	local direction = target - origin
	local result = workspace:Raycast(origin, direction, rayParams)

	return result == nil
end

local function findClosestTargetInCircle()
	local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local closestPlayer = nil
	local closestDist = CIRCLE_RADIUS

	local myChar = LocalPlayer.Character
	local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return nil end

	for _, player in ipairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end

		local char = player.Character
		if not char then continue end

		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then continue end

		local headPos = getHeadPosition(char)
		if not headPos then continue end

		local worldDist = (headPos - myHRP.Position).Magnitude
		if worldDist > MAX_DISTANCE then continue end

		if not hasLineOfSight(char) then continue end

		local screenPos, onScreen = worldToScreen(headPos)
		if not onScreen then continue end

		local screenDist = (screenPos - centerScreen).Magnitude
		if screenDist < closestDist then
			closestDist = screenDist
			closestPlayer = player
		end
	end

	return closestPlayer
end

local function aimAtTarget(character)
	local headPos = getHeadPosition(character)
	if not headPos then return end
	local camPos = Camera.CFrame.Position
	Camera.CFrame = CFrame.new(camPos, headPos)
end

local function fireWeapon()
	local char = LocalPlayer.Character
	if not char then return end
	local tool = char:FindFirstChildOfClass("Tool")
	if not tool then
		tool = LocalPlayer.Backpack:FindFirstChild(TOOL_NAME)
		if tool then
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			if humanoid then humanoid:EquipTool(tool) end
		end
		return
	end

	local remote = tool:FindFirstChild("RemoteEvent") or tool:FindFirstChild("Fire")
	if remote and remote:IsA("RemoteEvent") then
		remote:FireServer()
	else
		local activate = tool:FindFirstChild("Activate")
		if activate then activate:Fire() end
	end
end

-- ==================== TOGGLE (Double Click/Tap) ====================
local aimbotEnabled = true
local lockedTarget = nil
local lastFireTime = 0
local lastClickTime = 0
local DOUBLE_CLICK_THRESHOLD = 0.35

local function setEnabled(val)
	aimbotEnabled = val
	local color = val and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(100, 100, 100)
	UIStroke.Color = color
	CenterDot.BackgroundColor3 = color
end

Circle.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then

		local now = tick()
		if now - lastClickTime <= DOUBLE_CLICK_THRESHOLD then
			setEnabled(not aimbotEnabled)
			lastClickTime = 0
		else
			lastClickTime = now
		end
	end
end)

-- ==================== MAIN LOOP ====================
RunService.Heartbeat:Connect(function()
	if not aimbotEnabled then
		lockedTarget = nil
		return
	end

	lockedTarget = findClosestTargetInCircle()

	if lockedTarget and lockedTarget.Character then
		local char = lockedTarget.Character
		local hum = char:FindFirstChildOfClass("Humanoid")

		if hum and hum.Health > 0 then
			aimAtTarget(char)
			UIStroke.Color = Color3.fromRGB(255, 50, 50)

			local now = tick()
			if AUTO_FIRE and now - lastFireTime >= FIRE_RATE then
				fireWeapon()
				lastFireTime = now
			end
		else
			lockedTarget = nil
		end
	else
		UIStroke.Color = Color3.fromRGB(255, 200, 0)
	end
end)
