-- ===== Highlight =====
local function applyHighlight(target)
	local char = target.Character
	if not char then return end
	task.spawn(function()
		char:WaitForChild("HumanoidRootPart", 10)
		local h = char:FindFirstChild("Highlight")
	if not h then
    h = Instance.new("Highlight")
    h.Adornee = char
    h.Parent = char
end

h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
h.FillTransparency = 0.8
h.OutlineTransparency = 0
		if target == player then
			h.FillColor    = SELF_COLOR
			h.OutlineColor = SELF_COLOR
		else
			local ok, isFriend = pcall(function()
				return player:IsFriendsWith(target.UserId)
			end)
			if ok and isFriend then
				h.FillColor    = FRIEND_COLOR
				h.OutlineColor = FRIEND_COLOR
			else
				h.FillColor    = ENEMY_COLOR
				h.OutlineColor = ENEMY_COLOR
			end
		end
	end)
end

for _, p in Players:GetPlayers() do
	applyHighlight(p)
	p.CharacterAdded:Connect(function()
		task.wait(0.1)
		applyHighlight(p)
	end)
end

Players.PlayerAdded:Connect(function(p)
	applyHighlight(p)
	p.CharacterAdded:Connect(function()
		task.wait(0.1)
		applyHighlight(p)
	end)
end)

