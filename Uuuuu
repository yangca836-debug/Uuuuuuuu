local function makeSlider(yPos, label, icon, minV, maxV, defV, onChange)
	local c = Instance.new("Frame", content)
	c.Size                   = UDim2.new(1, -20, 0, 42)
	c.Position               = UDim2.new(0, 10, 0, yPos)
	c.BackgroundTransparency = 1

	local iconBox = Instance.new("Frame", c)
