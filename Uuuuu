-- ==================== AIMBOT FUNCTIONS ====================
local function getHeadPosition(char)
	local head = char:FindFirstChild("Head")
	if head then return head.Position end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if hrp then return hrp.Position end
	return nil
end

local function worldToScreen(pos)
	local sp, on = Camera:WorldToScreenPoint(pos)
	return Vector2.new(sp.X, sp.Y), on
end

local function hasLineOfSight(targetChar)
	local myChar = player.Character
	local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return false end
	local targetHead = targetChar:FindFirstChild("Head")
	if not targetHead then return false end
	local rp = RaycastParams.new()
	rp.FilterType = Enum.RaycastFilterType.Exclude
	rp.FilterDescendantsInstances = {myChar, targetChar}
	return workspace:Raycast(myHRP.Position + Vector3.new(0,1.5,0),
		targetHead.Position - (myHRP.Position + Vector3.new(0,1.5,0)), rp) == nil
end

local function findClosestTargetInCircle()
	local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	local closest, dist = nil, CIRCLE_RADIUS
	local myChar = player.Character
	local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return nil end
	for _, p in ipairs(Players:GetPlayers()) do
		if p == player then continue end
		if NO_FRIEND_AIM and isFriend(p) then continue end
		local char = p.Character
		if not char then continue end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then continue end
		local hp = getHeadPosition(char)
		if not hp then continue end
		if (hp - myHRP.Position).Magnitude > MAX_DISTANCE then continue end
		if not hasLineOfSight(char) then continue end
		local sp, on = worldToScreen(hp)
		if not on then continue end
		local d = (sp - center).Magnitude
		if d < dist then dist = d; closest = p end
	end
	return closest
end

local function aimAtTarget(char)
	local hp = getHeadPosition(char)
	if not hp then return end
	Camera.CFrame = CFrame.new(Camera.CFrame.Position, hp)
end

local function fireWeapon()
	local char = player.Character
	if not char then return end
	local tool = char:FindFirstChildOfClass("Tool")
	if not tool then
		tool = player.Backpack:FindFirstChild(TOOL_NAME)
		if tool then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum then hum:EquipTool(tool) end
		end
		return
	end
	local remote = tool:FindFirstChild("RemoteEvent") or tool:FindFirstChild("Fire")
	if remote and remote:IsA("RemoteEvent") then
		remote:FireServer()
	else
		local act = tool:FindFirstChild("Activate")
		if act then act:Fire() end
	end
end

-- ==================== TOGGLE double-click วงกลม ====================
local lockedTarget  = nil
local lastFireTime  = 0
local lastClickTime = 0
local DOUBLE_CLICK_THRESHOLD = 0.35

local function setEnabled(val)
	aimbotEnabled = val
	local color = val and Color3.fromRGB(255,50,50) or Color3.fromRGB(100,100,100)
	UIStroke.Color = color
	CenterDot.BackgroundColor3 = color
end

local function isInsideCircle(pos)
	local c = Vector2.new(
		Circle.AbsolutePosition.X + CIRCLE_RADIUS,
		Circle.AbsolutePosition.Y + CIRCLE_RADIUS)
	return (pos - c).Magnitude <= CIRCLE_RADIUS
end

UserInputService.InputBegan:Connect(function(input)
	if not scriptActive then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		local pos = Vector2.new(input.Position.X, input.Position.Y)
		if not isInsideCircle(pos) then return end
		local now = tick()
		if now - lastClickTime <= DOUBLE_CLICK_THRESHOLD then
			setEnabled(not aimbotEnabled)
			lastClickTime = 0
		else
			lastClickTime = now
		end
	end
end)

-- ==================== MAIN LOOP ====================
RunService.Heartbeat:Connect(function()
	if not scriptActive then return end
	if not aimbotEnabled then lockedTarget = nil; return end
	lockedTarget = findClosestTargetInCircle()
	if lockedTarget and lockedTarget.Character then
		local char = lockedTarget.Character
		local hum  = char:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then
			aimAtTarget(char)
			UIStroke.Color = Color3.fromRGB(255,50,50)
			local now = tick()
			if AUTO_FIRE and now - lastFireTime >= FIRE_RATE then
				fireWeapon(); lastFireTime = now
			end
		else
			lockedTarget = nil
		end
	else
		UIStroke.Color = Color3.fromRGB(255,200,0)
	end
end)

setEnabled(true)
