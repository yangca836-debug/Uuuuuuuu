-- ===== Friend Cache =====
local friendCache = {}
local function isFriend(target)
	if friendCache[target.UserId] ~= nil then return friendCache[target.UserId] end
	local ok, result = pcall(function() return player:IsFriendsWith(target.UserId) end)
	friendCache[target.UserId] = ok and result or false
	return friendCache[target.UserId]
end

-- ===== Highlight =====
local highlightInstances = {}

local function applyHighlight(target)
	local char = target.Character
	if not char then return end
	task.spawn(function()
		char:WaitForChild("HumanoidRootPart", 10)
		char:WaitForChild("Humanoid", 10)
		local h = char:FindFirstChild("Highlight")
		if not h then
			h = Instance.new("Highlight")
			h.Adornee = char
			h.Parent  = char
		end
		highlightInstances[target.UserId] = h
		h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
		h.FillTransparency    = 0.25
		h.OutlineTransparency = 0
		h.Enabled = highlightOn
		if target == player then
			h.FillColor = SELF_COLOR; h.OutlineColor = SELF_COLOR
		elseif isFriend(target) then
			h.FillColor = FRIEND_COLOR; h.OutlineColor = FRIEND_COLOR
		else
			h.FillColor = ENEMY_COLOR; h.OutlineColor = ENEMY_COLOR
		end
	end)
end

local function setHighlightAll(val)
	for _, h in pairs(highlightInstances) do
		if h and h.Parent then h.Enabled = val end
	end
end

local function setupPlayer(p)
	if p.Character then applyHighlight(p) end
	p.CharacterAdded:Connect(function() task.wait(0.1); applyHighlight(p) end)
end

for _, p in Players:GetPlayers() do setupPlayer(p) end
