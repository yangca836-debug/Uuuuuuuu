	local pill = Instance.new("Frame", row)
	pill.Size                   = UDim2.new(0, 28, 0, 18)
	pill.Position               = UDim2.new(0, 0, 0, 2)
	pill.BackgroundColor3       = Color3.fromRGB(255, 255, 255)
	pill.BackgroundTransparency = 0.92
	pill.BorderSizePixel        = 0
	pill.ZIndex                 = 3
	Instance.new("UICorner", pill).CornerRadius = UDim.new(0, 5)

	local iconL = Instance.new("TextLabel", pill)
	iconL.Size                   = UDim2.new(1, 0, 1, 0)
	iconL.BackgroundTransparency = 1
	iconL.Text                   = iconText
	iconL.TextColor3             = Color3.fromRGB(170, 170, 180)
	iconL.TextSize               = 9
	iconL.Font                   = Enum.Font.GothamBold
	iconL.ZIndex                 = 4

	-- Label
	local namL = Instance.new("TextLabel", row)
	namL.Size                   = UDim2.new(0.58, 0, 0, 16)
	namL.Position               = UDim2.new(0, 34, 0, 2)
	namL.BackgroundTransparency = 1
	namL.Text                   = labelText
	namL.TextColor3             = Color3.fromRGB(155, 155, 165)
	namL.TextSize               = 9
	namL.Font                   = Enum.Font.Gotham
	namL.TextXAlignment         = Enum.TextXAlignment.Left
	namL.ZIndex                 = 3

	-- Value
	local valL = Instance.new("TextLabel", row)
	valL.Size                   = UDim2.new(0.42, -34, 0, 16)
	valL.Position               = UDim2.new(0.58, 0, 0, 2)
	valL.BackgroundTransparency = 1
	valL.Text                   = "+0"
	valL.TextColor3             = Color3.fromRGB(225, 225, 230)
	valL.TextSize               = 9
	valL.Font                   = Enum.Font.GothamBold
	valL.TextXAlignment         = Enum.TextXAlignment.Right
	valL.ZIndex                 = 3

	-- Track bg
	local track = Instance.new("Frame", row)
	track.Size                   = UDim2.new(1, 0, 0, 4)
	track.Position               = UDim2.new(0, 0, 0, 26)
	track.BackgroundColor3       = Color3.fromRGB(255, 255, 255)
	track.BackgroundTransparency = 0.9
	track.BorderSizePixel        = 0
	track.ZIndex                 = 3
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

	-- Fill
	local fill = Instance.new("Frame", track)
	fill.Size              = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3  = Color3.fromRGB(200, 200, 210)
	fill.BorderSizePixel   = 0
	fill.ZIndex            = 4
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	-- Thumb
	local thumb = Instance.new("Frame", track)
	thumb.Size             = UDim2.new(0, 12, 0, 12)
	thumb.AnchorPoint      = Vector2.new(0.5, 0.5)
	thumb.Position         = UDim2.new(0, 0, 0.5, 0)
	thumb.BackgroundColor3 = Color3.fromRGB(240, 240, 245)
	thumb.BorderSizePixel  = 0
	thumb.ZIndex           = 5
	Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

	-- Thumb inner dot
	local dot = Instance.new("Frame", thumb)
	dot.Size             = UDim2.new(0, 4, 0, 4)
	dot.AnchorPoint      = Vector2.new(0.5, 0.5)
	dot.Position         = UDim2.new(0.5, 0, 0.5, 0)
	dot.BackgroundColor3 = Color3.fromRGB(120, 120, 130)
	dot.BorderSizePixel  = 0
	dot.ZIndex           = 6
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	-- Drag logic (smooth)
	local dragging   = false
	local targetPct  = 0
	local currentPct = 0

	local function update(pos)
		local ax = track.AbsolutePosition.X
		local aw = track.AbsoluteSize.X
		targetPct = math.clamp((pos.X - ax) / aw, 0, 1)
		local v = math.round(minV + targetPct * (maxV - minV))
		valL.Text = "+"..tostring(v)
		onChange(v)
	end

	-- Smooth lerp on heartbeat
	RunService.Heartbeat:Connect(function(dt)
		if math.abs(currentPct - targetPct) > 0.001 then
			currentPct = currentPct + (targetPct - currentPct) * math.min(dt * 20, 1)
			fill.Size      = UDim2.new(currentPct, 0, 1, 0)
			thumb.Position = UDim2.new(currentPct, 0, 0.5, 0)
		end
	end)

	track.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true; update(i.Position)
		end
	end)
	thumb.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then dragging = true end
	end)
	UserInputService.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
		or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position) end
	end)
	UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
	end)
end

