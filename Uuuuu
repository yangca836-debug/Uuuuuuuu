-- ==================== FUNCTIONS ====================

local function getHeadPosition(character)
	local head = character:FindFirstChild("Head")
	if head then return head.Position end
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if hrp then return hrp.Position end
	return nil
end

local function worldToScreen(pos)
	local screenPos, onScreen = Camera:WorldToScreenPoint(pos)
	return Vector2.new(screenPos.X, screenPos.Y), onScreen
end

local function hasLineOfSight(targetCharacter)
	local myChar = LocalPlayer.Character
	local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return false end

	local targetHead = targetCharacter:FindFirstChild("Head")
	if not targetHead then return false end

	local origin = myHRP.Position + Vector3.new(0, 1.5, 0)
	local target = targetHead.Position

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {myChar, targetCharacter}

	local direction = target - origin
	local result = workspace:Raycast(origin, direction, rayParams)

	return result == nil
end

local function findClosestTargetInCircle()
	local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local closestPlayer = nil
	local closestDist = CIRCLE_RADIUS

	local myChar = LocalPlayer.Character
	local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return nil end

	for _, player in ipairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end

		local char = player.Character
		if not char then continue end

		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then continue end

		local headPos = getHeadPosition(char)
		if not headPos then continue end

		local worldDist = (headPos - myHRP.Position).Magnitude
		if worldDist > MAX_DISTANCE then continue end

		if not hasLineOfSight(char) then continue end

		local screenPos, onScreen = worldToScreen(headPos)
		if not onScreen then continue end

		local screenDist = (screenPos - centerScreen).Magnitude
		if screenDist < closestDist then
			closestDist = screenDist
			closestPlayer = player
		end
	end

	return closestPlayer
end

local function aimAtTarget(character)
	local headPos = getHeadPosition(character)
	if not headPos then return end
	local camPos = Camera.CFrame.Position
	Camera.CFrame = CFrame.new(camPos, headPos)
end

local function fireWeapon()
	local char = LocalPlayer.Character
	if not char then return end
	local tool = char:FindFirstChildOfClass("Tool")
	if not tool then
		tool = LocalPlayer.Backpack:FindFirstChild(TOOL_NAME)
		if tool then
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			if humanoid then humanoid:EquipTool(tool) end
		end
		return
	end

	local remote = tool:FindFirstChild("RemoteEvent") or tool:FindFirstChild("Fire")
	if remote and remote:IsA("RemoteEvent") then
		remote:FireServer()
	else
		local activate = tool:FindFirstChild("Activate")
		if activate then activate:Fire() end
	end
end

-- ==================== TOGGLE ====================
local aimbotEnabled = true
local lockedTarget = nil
local lastFireTime = 0
local lastClickTime = 0
local DOUBLE_CLICK_THRESHOLD = 0.35

local function setEnabled(val)
	aimbotEnabled = val
	local color = val and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(100, 100, 100)
	UIStroke.Color = color
	CenterDot.BackgroundColor3 = color
end

local function isInsideCircle(pos)
	local center = Vector2.new(
		Circle.AbsolutePosition.X + CIRCLE_RADIUS,
		Circle.AbsolutePosition.Y + CIRCLE_RADIUS
	)
	return (pos - center).Magnitude <= CIRCLE_RADIUS
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then

		local pos = Vector2.new(input.Position.X, input.Position.Y)
		if not isInsideCircle(pos) then return end

		local now = tick()
		if now - lastClickTime <= DOUBLE_CLICK_THRESHOLD then
			setEnabled(not aimbotEnabled)
			lastClickTime = 0
		else
			lastClickTime = now
		end
	end
end)

-- ==================== MAIN LOOP ====================
RunService.Heartbeat:Connect(function()
	if not aimbotEnabled then
		lockedTarget = nil
		return
	end

	lockedTarget = findClosestTargetInCircle()

	if lockedTarget and lockedTarget.Character then
		local char = lockedTarget.Character
		local hum = char:FindFirstChildOfClass("Humanoid")

		if hum and hum.Health > 0 then
			aimAtTarget(char)
			UIStroke.Color = Color3.fromRGB(255, 50, 50)

			local now = tick()
			if AUTO_FIRE and now - lastFireTime >= FIRE_RATE then
				fireWeapon()
				lastFireTime = now
			end
		else
			lockedTarget = nil
		end
	else
		UIStroke.Color = Color3.fromRGB(255, 200, 0)
	end
end)
